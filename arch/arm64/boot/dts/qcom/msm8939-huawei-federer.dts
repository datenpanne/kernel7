/dts-v1/;

#include "msm8939-pm8916.dtsi"
#include "msm8916-modem-qdsp6.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pinctrl/qcom,pmic-gpio.h>
#include <dt-bindings/pinctrl/qcom,pmic-mpp.h>
//#include <dt-bindings/sound/apq8016-lpass.h>

/ {
	model = "Huawei MediaPad T2 Pro 10.0";
	compatible = "huawei,federer", "qcom,msm8939";
	chassis-type = "tablet";

	aliases {
		mmc0 = &sdhc_1; /* eMMC */
		mmc1 = &sdhc_2; /* SD card */
		serial0 = &blsp_uart2;
		i2c0 = &blsp_i2c2;
	};

	chosen {
		stdout-path = "serial0";
	};

	reserved-memory {
	/*	cont_splash_mem: framebuffer@83000000 {
			compatible = "removed-dma-pool";
			reg = <0x0 0x83000000 0x0 0x1A00000>;
			no-map;
		};

		reserved@85000000 {
			reg = <0x0 0x85000000 0x0 0x1000000>;
			no-map;
		};*/

		qseecom_mem: qseecom@84a00000 {
			reg = <0x0 0x84a00000 0x0 0x1600000>;
			no-map;
		};

		tz-hwlog@8c700000 {
			reg = <0x0 0x8c700000 0x0 0x400000>;
			no-map;
		};

		ramoops@8cb00000 {
			compatible = "ramoops";
			reg = <0x0 0x8cb00000 0x0 0x200000>;

			record-size = <0x10000>;
			console-size = <0x100000>;
			ftrace-size = <0>;
		};
	};

	battery: battery {
		compatible = "simple-battery";
		device-chemistry = "lithium-ion-polymer";

		voltage-min-design-microvolt = <3350000>;
		voltage-max-design-microvolt = <4350000>;
		energy-full-design-microwatt-hours = <24700000>;
		charge-full-design-microamp-hours = <6500000>;

		precharge-current-microamp = <1300000>;
		charge-term-current-microamp = <260000>; //4%(from vendor dts)

		/*
		//charge-term-current-microamp = <650000>;

		//constant-charge-voltage-max-microvolt = <3800000>; //not charging?
		constant-charge-voltage-max-microvolt = <4350000>;

		factory-internal-resistance-micro-ohms = <118000>;
		//operating-range-celsius = <0 52>;
		//alert-celsius = <10 42>;*/

		ocv-capacity-celsius = <(-25) 0 25>;
		/* table for -20 degree Celsius  data from HB26A510EBC_GY_SWD-4v35-6500mah.dtsi*/
		ocv-capacity-table-0 =  <4316000 100>,  <4200000 95>,  <4124000 90>,
			<4025000 85>,  <3964000 80>,  <3918000 75>,  <3883000 70>,
 			<3857000 65>,  <3836000 60>,  <3817000 55>,  <3800000 50>,
			 <3785000 45>,  <3770000 40>,  <3754000 35>,  <3737000 30>,
			 <3717000 25>,  <3694000 20>,  <3669000 16>,  <3645000 13>,
			 <3628000 11>,  <3616000 10>,  <3604000 9>,  <3586000 8>,
			 <3568000 7>,  <3544000 6>,  <3516000 5>,  <3478000 4>,
			 <3428000 3>,  <3360000 2>,  <3250000 1>,  <3000000 0>;
		/* table for 0 degree Celsius */
		ocv-capacity-table-1 =  <4315000 100>, <4250000 95>, <4190000 90>,
			<4136000 85>, <4085000 80>, <4032000 75>, <3957000 70>,
			<3918000 65>, <3885000 60>, <3854000 55>, <3828000 50>,
			<3806000 45>, <3790000 40>, <3777000 35>, <3765000 30>,
			<3751000 25>, <3732000 20>, <3712000 16>, <3698000 13>,
			<3690000 11>, <3686000 10>, <3680000 9>, <3674000 8>,
			<3664000 7>, <3648000 6>, <3623000 5>, <3584000 4>,
			<3530000 3>, <3449000 2>, <3316000 1>, <3000000 0>;
		/* table for 25 degree Celsius */
		ocv-capacity-table-2 = <4315000 100>, <4260000 95>, <4204000 90>,
			<4150000 85>, <4098000 80>, <4054000 75>, <3988000 70>,
			<3953000 65>, <3910000 60>, <3868000 55>, <3838000 50>,
			<3816000 45>, <3798000 40>, <3782000 35>, <3769000 30>,
			<3754000 25>, <3736000 20>, <3716000 16>, <3696000 13>,
			<3688000 11>, <3686000 10>, <3684000 9>, <3682000 8>,
			<3678000 7>, <3668000 6>, <3644000 5>, <3600000 4>,
			<3540000 3>, <3458000 2>, <3325000 1>, <3000000 0>;
	};

	gpio-hall-sensor {
		compatible = "gpio-keys";

		pinctrl-0 = <&gpio_hall_sensor_default>;
		pinctrl-names = "default";

		label = "GPIO Hall Effect Sensor";

		event-hall-sensor {
			label = "Hall Effect Sensor";
			gpios = <&tlmm 69 GPIO_ACTIVE_LOW>;
			linux,input-type = <EV_SW>;
			linux,code = <SW_LID>;
			linux,can-disable;
		};
	};

	gpio-keys {
		compatible = "gpio-keys";

		pinctrl-0 = <&gpio_keys_default>;
		pinctrl-names = "default";

		label = "GPIO Buttons";

		button-volume-up {
			label = "Volume Up";
			gpios = <&tlmm 107 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_VOLUMEUP>;
		};
	};

	gpio-leds {
		compatible = "gpio-leds";

		pinctrl-0 = <&gpio_leds_default>;
		pinctrl-names = "default";

		led-0 {
			gpios = <&tlmm 8 GPIO_ACTIVE_HIGH>;
			color = <LED_COLOR_ID_RED>;
			default-state = "off";
			function = LED_FUNCTION_INDICATOR;
			retain-state-suspended;
		};

		led-1 {
			gpios = <&tlmm 9 GPIO_ACTIVE_HIGH>;
			color = <LED_COLOR_ID_GREEN>;
			default-state = "off";
			function = LED_FUNCTION_INDICATOR;
			retain-state-suspended;
		};

		led-2 {
			gpios = <&tlmm 10 GPIO_ACTIVE_HIGH>;
			color = <LED_COLOR_ID_BLUE>;
			default-state = "off";
			function = LED_FUNCTION_INDICATOR;
			retain-state-suspended;
		};
	};

	/*headphones_switch: audio-switch {
		compatible = "simple-audio-amplifier";
		VCC-supply = <&speaker_vdd>;
		enable-gpios = <&tlmm 1 GPIO_ACTIVE_LOW>;

		pinctrl-0 = <&headphones_switch_default>;
		pinctrl-1 = <&headphones_switch_sleep>;
		pinctrl-names = "default","sleep";

		sound-name-prefix = "Headphones Switch";
	};*/

	speaker_boost: regulator-speaker-boost {
		compatible = "regulator-fixed";
		regulator-name = "speaker-boost";
		gpios = <&tlmm 2 GPIO_ACTIVE_HIGH>; // Boost GPIO
		enable-active-high;
		
		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&speaker_boost_default>;
		pinctrl-1 = <&speaker_boost_sleep>;
	};

	speaker_vdd: regulator-speaker-vdd {
		compatible = "regulator-fixed";
		regulator-name = "speaker-vdd";
		gpios = <&tlmm 0 GPIO_ACTIVE_HIGH>; // VDD Switch
		enable-active-high;
		regulator-always-on;
		/*pinctrl-0 = <&speaker_vdd_default>;
		pinctrl-1 = <&speaker_vdd_sleep>;
		pinctrl-names = "default","sleep";*/
	};

	speaker_amp: audio-amplifier {
		compatible = "simple-audio-amplifier";
		VCC-supply = <&speaker_vdd>;
		vin-supply = <&speaker_boost>;
		enable-gpios = <&tlmm 3 GPIO_ACTIVE_HIGH>; // Enable GPIO
		startup-delay-us = <200000>;

		pinctrl-0 = <&speaker_amp_default &headphones_switch_default>;
		pinctrl-1 = <&speaker_amp_sleep &headphones_switch_sleep>;
		pinctrl-names = "default","sleep";
		
		sound-name-prefix = "Speaker";
	};

	reg_tp_vdd: regulator-tp-vdd {
		compatible = "regulator-fixed";
		regulator-name = "tp_vdd";
		regulator-min-microvolt = <1850000>;
		regulator-max-microvolt = <1850000>;
		gpios = <&tlmm 112 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-always-on;
	};


	reg_lcd_vddio: regulator-lcd-vddio {
		compatible = "regulator-fixed";
		regulator-name = "lcd_vddio";

		vin-supply = <&pm8916_l6>;
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-boot-on;
		gpios = <&tlmm 109 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		startup-delay-us = <100000>;

		/*pinctrl-0 = <&lcd_vddio_default>;
		pinctrl-names = "default";*/
	};
	
	reg_lcd_vsp: regulator-lcd-vsp {
		compatible = "regulator-fixed";
		regulator-name = "lcd_vsp";

		vin-supply = <&reg_lcd_vddio>;
		regulator-min-microvolt = <5400000>;
		regulator-max-microvolt = <5400000>;
		regulator-boot-on;
		//regulator-always-on;

		gpios = <&tlmm 97 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		startup-delay-us = <10000>;

		/*pinctrl-names = "default";
		pinctrl-0 = <&lcd_vsp_default>;*/
	};

	reg_lcd_vsn: regulator-lcd-vsn {
		compatible = "regulator-fixed";
		regulator-name = "lcd_vsn";

		vin-supply = <&reg_lcd_vsp>;		
		regulator-min-microvolt = <5400000>;
		regulator-max-microvolt = <5400000>;
		regulator-boot-on;
		//regulator-always-on;

		gpios = <&tlmm 32 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		startup-delay-us = <10000>;

		/*pinctrl-names = "default";
		pinctrl-0 = <&lcd_vsn_default>;*/
	};

	otg_path: otg_path {
		compatible = "regulator-fixed";
		regulator-name = "otg-path";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpios = <&tlmm 108 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		vin-supply = <&usb_otg_vbus>;	/* request otg booster of bq24296 */
	};

	usb_id: usb-id {
		compatible = "linux,extcon-usb-gpio";
		id-gpios = <&tlmm 117 GPIO_ACTIVE_HIGH>;
		pinctrl-0 = <&usb_id_default>;
		pinctrl-names = "default";
	};
};

&blsp_i2c2 {
	status = "okay";

	accelerometer@1f {
		compatible = "kionix,kx023-1025";
		reg = <0x1f>;

		vdd-supply = <&pm8916_l17>;
		vddio-supply = <&pm8916_l6>;
		pinctrl-0 = <&accel_int_default>;
		pinctrl-names = "default";
		mount-matrix =  "-1", "0", "0",
				"0", "-1", "0",
				"0", "0", "1";
	};

	light@38 {
		compatible = "rohm,bh1745";
		reg = <0x38>;

		vdd-supply = <&pm8916_l17>;
		vio-supply = <&pm8916_l6>;
	};

	flash-led-controller@63 {
		compatible = "leds-lm3642";
		reg = <0x63>;

		pinctrl-0 = <&camera_rear_flash_default>;
		pinctrl-1 = <&camera_rear_flash_sleep>;
		pinctrl-names = "default","sleep";

		//gpios = <&tlmm 86 GPIO_ACTIVE_HIGH>,<&tlmm 31 GPIO_ACTIVE_HIGH >;

		flash_led {
			linux,default-trigger = "flash";
			function = LED_FUNCTION_FLASH;
			color = <LED_COLOR_ID_WHITE>;
			gpios = <&tlmm 86 GPIO_ACTIVE_HIGH>;
			led-sources = <0>, <1>;
		};
		torch_led {
			linux,default-trigger = "torch";
			function = LED_FUNCTION_TORCH;
			color = <LED_COLOR_ID_WHITE>;
			gpios = <&tlmm 31 GPIO_ACTIVE_HIGH >;
			led-sources = <0>, <0>;
		};
	};
};

&blsp_i2c4 {
	status = "okay";
	charger: bq24192@6b {
		compatible = "ti,bq24296";
		reg = <0x6b>;
		interrupt-parent = <&tlmm>;
		interrupts = <62 IRQ_TYPE_EDGE_FALLING>;
		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&bq24192_charger_default &bq24192_charger_en_default>;
		pinctrl-1 = <&bq24192_charger_default>;
		monitored-battery = <&battery>;
		//ti,system-minimum-microvolt = <3350000>;
		omit-battery-class;
		usb_otg_vbus: usb-otg-vbus {
		};
	};
};

&blsp_i2c5 {
	status = "okay";
	clock-frequency = <400000>;

	touchscreen@1a {
		compatible = "cypress,tt21000";
		reg = <0x1a>;

		interrupt-parent = <&tlmm>;
		interrupts = <13 IRQ_TYPE_EDGE_FALLING>;

		reset-gpios = <&tlmm 12 GPIO_ACTIVE_LOW>;

		vdd-supply = <&reg_tp_vdd>;
		vddio-supply = <&pm8916_l16>;

		pinctrl-0 = <&touchscreen_default>;
		pinctrl-names = "default";
	};
};

&blsp_uart2 {
	pinctrl-0 = <&blsp_uart2_console_default>;
	pinctrl-1 = <&blsp_uart2_console_sleep>;
	pinctrl-names = "default", "sleep";
	status = "okay";
};

&gpu {
	status = "okay";
};

&mdss {
	status = "okay";
};

&mdss_dsi0 {
	pinctrl-0 = <&mdss_default>;// &mdss_te_default>;
	pinctrl-1 = <&mdss_sleep>;// &mdss_te_sleep>;
	pinctrl-names = "default", "sleep";
	status = "okay";

	panel@0 {
		//compatible = "huawei,boe-nt51021";
		compatible = "huawei,federer-panel";
		reg = <0>;

		/*vddio-supply = <&reg_lcd_vddio>;
		vsp-supply = <&reg_lcd_vsp_vsn>;
		vsn-supply = <&reg_lcd_vsp_vsn>;*/
		vcc-gpios = <&tlmm 32 GPIO_ACTIVE_HIGH>;	
		blpwr-gpios = <&tlmm 109 GPIO_ACTIVE_HIGH>;
		backlight-gpios = <&tlmm 97 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&tlmm 25 GPIO_ACTIVE_LOW>;
		
	//	te-gpios = <&tlmm 24 GPIO_ACTIVE_HIGH>;

		port {
			panel_in: endpoint {
				remote-endpoint = <&mdss_dsi0_out>;
			};
		};
	};
};

&mdss_dsi0_out {
	data-lanes = <0 1 2 3>;
	remote-endpoint = <&panel_in>;
};

&mdss_dsi0_phy {
	qcom,dsi-phy-regulator-ldo-mode;
	status = "okay";
};

&mpss_mem {
	reg = <0x0 0x86800000 0x0 0x5600000>;
	//reg = <0x0 0x86800000 0x0 0x2b00000>;
};

&pm8916_bms {
	monitored-battery = <&battery>;
	power-supplies = <&charger>;

	status = "okay";
};

/*
&pm8916_charger {
	monitored-battery = <&battery>;
	status = "okay";
};*/

&pm8916_codec {
	qcom,micbias-lvl = <2800>;
	qcom,mbhc-vthreshold-low = <75 150 237 450 500>;
	qcom,mbhc-vthreshold-high = <75 150 237 450 500>;
	qcom,micbias1-ext-cap;
	qcom,hphl-jack-type-normally-open;
	status = "okay";
};

&pm8916_mpps {
	pinctrl-names = "default";
	pinctrl-0 = <&pm8916_mpp2_in &pm8916_mpp4_in>;

	pm8916_mpp2_in: pm8916-mpp2-in-state {
		pinconf {
			pins = "mpp2";
			function = "analog"; //input
			qcom,amux-route = <1>; //PMIC_MPP_AMUX_ROUTE_CH6
		};
	};

	pm8916_mpp4_in: pm8916-mpp4-in-state {
		pinconf {
			pins = "mpp4";
			function = "analog"; //input
			qcom,amux-route = <3>; //PMIC_MPP_AMUX_ROUTE_CH8
		};
	};
};

&pm8916_resin {
	linux,code = <KEY_VOLUMEDOWN>;
	status = "okay";
};

&pm8916_rpm_regulators {
	pm8916_l6: l6 {
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on; 
		regulator-boot-on;
	};

	pm8916_l8: l8 {
		regulator-min-microvolt = <2950000>;
		regulator-max-microvolt = <2950000>;
	};

	pm8916_l16: l16 {
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-boot-on;
	};

	pm8916_l17: l17 {
		regulator-min-microvolt = <2850000>;
		regulator-max-microvolt = <2850000>;
		regulator-always-on; 
		regulator-boot-on;
	};
};

&pm8916_vadc {
	channel@2 {
		reg = <VADC_VCHG_SNS>;
		qcom,pre-scaling = <10 81>;
		label = "ireg_fb";
	};

	channel@5 {
		reg = <VADC_VCOIN>;
		qcom,pre-scaling = <1 3>;
		label = "vcoin";
	};

	channel@6 {
		reg = <VADC_VBAT_SNS>;
		qcom,pre-scaling = <1 3>;
		label = "vbat_sns";
	};

	/* cam therm */
	channel@11 {
		reg = <VADC_P_MUX2_1_1>;
		qcom,decimation = <512>;
		qcom,pre-scaling = <1 1>;
		qcom,hw-settle-time = <200>;
		qcom,avg-samples = <1>;
		label = "mpp2_div1";
	};

	/* cpu therm */
	channel@13 {
		reg = <VADC_P_MUX4_1_1>;
		qcom,decimation = <512>;
		qcom,pre-scaling = <1 1>;
		qcom,hw-settle-time = <200>;
		qcom,avg-samples = <1>;
		label = "mpp4_div1";
	};

	channel@30 {
		reg = <VADC_LR_MUX1_BAT_THERM>;
		qcom,pre-scaling = <1 1>;
		qcom,ratiometric;
		qcom,hw-settle-time = <200>;
		qcom,avg-samples = <1>;
		label = "batt_therm";
	};

	channel@31 {
		reg = <VADC_LR_MUX2_BAT_ID>;
		qcom,pre-scaling = <1 1>;
		qcom,ratiometric;
		qcom,hw-settle-time = <200>;
		label = "batt_id";
	};

	channel@32 {
		reg = <VADC_LR_MUX3_XO_THERM>;
		qcom,pre-scaling = <1 1>;
		qcom,ratiometric;
		qcom,hw-settle-time = <200>;
		label = "xo_therm";
	};

	/* pa therm0 */
	channel@36 {
		reg = <VADC_LR_MUX7_HW_ID>;
		qcom,pre-scaling = <1 1>;
		qcom,ratiometric;
		qcom,hw-settle-time = <200>;
		label = "pa_therm0";
	};

	channel@3c {
		reg = <VADC_LR_MUX3_BUF_XO_THERM>;
		qcom,pre-scaling = <1 1>;
		qcom,ratiometric;
		qcom,hw-settle-time = <200>;
		label = "xo_therm_buf";
	};

	channel@b {
		reg = <VADC_CHG_TEMP>;
		//reg = <0xb>;
		qcom,pre-scaling = <1 1>;
		qcom,hw-settle-time = <0>;
		label = "chg_temp";
	};
};

&pm8916_vib {
	status = "okay";
};

&sdhc_1 {
	status = "okay";
};

&sdhc_2 {
	pinctrl-0 = <&sdc2_default &sdc2_cd_default>;
	pinctrl-1 = <&sdc2_sleep &sdc2_cd_default>;
	pinctrl-names = "default", "sleep";

	cd-gpios = <&tlmm 38 GPIO_ACTIVE_LOW>;

	status = "okay";
};

&sound {
	status = "okay";

	model = "wt86528";
	widgets =
		"Speaker", "Speaker",
		"Headphone", "Headphones";
	pin-switches = "Speaker";
	audio-routing =
		"Speaker", "Speaker OUTL",
		"Speaker", "Speaker OUTR",
		"Speaker INL", "HPH_L",
		"Speaker INR", "HPH_R",
		"Headphones", "HPH_L",
		"Headphones", "HPH_R",
		"AMIC1", "MIC BIAS External1",
		"AMIC2", "MIC BIAS External2",
		"AMIC3", "MIC BIAS External1";
	aux-devs = <&speaker_amp>;
};

&usb {
	//extcon = <&usb_id>, <&usb_id>;
	extcon = <&charger>, <&usb_id>;
	vbus-supply = <&otg_path>;

	status = "okay";
};

&venus_mem {
	status = "okay";
};

&usb_hs_phy {
	//extcon = <&usb_id>;
	extcon = <&charger>;

	/*qcom,init-seq = /bits/ 8 <0x0 0x74>,
				<0x1 0x65>,
				<0x2 0x31>,
				<0x3 0x33>;*/
};

&wcnss {
	status = "okay";
};

&wcnss_iris {
	compatible = "qcom,wcn3660b";
};

&wcnss_mem {
	status = "okay";
};

&tlmm {
	accel_int_default: accel-int-default-state {
		pins = "gpio115";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	bq24192_charger_default: bq24196-charger-default-state  {
		pins = "gpio62";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
	};

	bq24192_charger_en_default: bq24196-charger-en-default-state  {
		pins = "gpio108";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
		output-low;
	};

	camera_rear_flash_default: camera-rear-flash-default-state {
		pins = "gpio31", "gpio86";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	camera_rear_flash_sleep: camera-rear-flash-sleep-state {
		pins = "gpio31", "gpio86";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

	gpio_hall_sensor_default: gpio-hall-sensor-default-state {
		pins = "gpio69";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	gpio_keys_default: gpio-keys-default-state {
		pins = "gpio107";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
	};

	gpio_leds_default: gpio-leds-default-state {
		pins = "gpio8", "gpio9", "gpio10";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	/* GPIO 1 - Headphones Switch */
	headphones_switch_default: headphones-switch-default {
		pins = "gpio1";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up; /* Falls High = Kopfhörer-Pfad aktiv */
	};

	headphones_switch_sleep: headphones-switch-sleep {
		pins = "gpio1";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

	/*light_irq_default: light-irq-default-state {
		pins = "gpio113";
		function = "gpio";
		drive-strength = <6>;
		input-enable;
		bias-disable;
	};

	light_irq_sleep: light-irq-sleep-state {
		pins = "gpio113";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};*/

	/*lcd_vsp_vsn_default: lcd-vsp-vsn-default-state {
		pins = "gpio109";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
		output-high;
	};

	lcd_vddio_default: lcd-vddio-default-state {
		pins = "gpio32";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
		output-high;
	};*/
	
	mdss_default: mdss-default-state {
		pins = "gpio25";
		function = "gpio";
		drive-strength = <8>;
		bias-disable;
	};

	mdss_sleep: mdss-sleep-state {
		pins = "gpio25";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

/*	mdss_te_default: mdss-te-default-state {
		pins = "gpio24";
		function = "gpio";
		//function = "mdp_vsync";
		drive-strength = <2>;
		bias-pull-disable;
	};

	mdss_te_sleep: mdss-te-sleep-state {
		pins = "gpio24";
		function = "gpio";
		//function = "mdp_vsync";
		drive-strength = <2>;
		bias-pull-down;
	};*/

	sdc2_cd_default: sdc2-cd-default-state {
		pins = "gpio38";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	/* GPIO 3 - Speaker Enable */
	speaker_amp_default: speaker-amp-default {
		pins = "gpio3";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
	};

	speaker_amp_sleep: speaker-amp-sleep {
		pins = "gpio3";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

	/* GPIO 2 - Speaker Boost */
	speaker_boost_default: speaker-boost-default {
		pins = "gpio2";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
	};

	speaker_boost_sleep: speaker-boost-sleep {
		pins = "gpio2";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

	/* GPIO 0 - Speaker VDD */
	speaker_vdd_default: speaker-vdd-default {
		pins = "gpio0";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
	};

	speaker_vdd_sleep: speaker-vdd-sleep {
		pins = "gpio0";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

	touchscreen_default: touchscreen-default-state {
		pins = "gpio12", "gpio13";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	usb_id_default: usb-id-default-state {
		pins = "gpio117";
		function = "gpio";
		drive-strength = <8>;
		bias-pull-up;
	};
};

/ {
	fuel-gauge {
	compatible = "adc-battery";
	// #address-cells = <1>;
	//#size-cells = <0>;

		io-channels = <&pm8916_vadc 0x6>, <&pm8916_vadc 0x11>, <&pm8916_vadc 0x30>;
		io-channel-names = "voltage","current","temperature";

		//charged-gpios = <&tlmm 62>;
		monitored-battery = <&battery>;
		power-supplies = <&charger>;
	};
};
